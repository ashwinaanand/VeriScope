# backend/phrase_detector.py (update)
cat > backend/phrase_detector.py <<'EOF'
import json

def load_phrases():
    with open("backend/phrase_config.json") as f:
        data = json.load(f)
    return data["phrases"]

def flag_text(text: str):
    phrases = load_phrases()
    flagged = [p for p in phrases if p.lower() in text.lower()]
    return flagged
EOF

git add backend/phrase_config.json backend/phrase_detector.py
